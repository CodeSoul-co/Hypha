{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "../../dist/apps/server",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@core/*": ["./core/*"],
      "@config/*": ["./config/*"],
      "@routes/*": ["./routes/*"],
      "@models/*": ["./models/*"],
      "@middleware/*": ["./middleware/*"],
      "@services/*": ["./services/*"],
      "@utils/*": ["./utils/*"],
      "@types/*": ["./types/*"],
      "@constants/*": ["./constants/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "../../dist", "../../tests"]
}
