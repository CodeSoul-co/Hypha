# Application
NODE_ENV=development
PORT=3000

# MongoDB
# Local default: mongodb://localhost:27017/hypha
# Cloud override: set MONGODB_URI to a MongoDB Atlas connection string.
# Leave MONGODB_URI empty to use the local host/port settings below.
MONGODB_URI=
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hypha
MONGODB_USERNAME=
MONGODB_PASSWORD=

# Redis
# Local default: redis://localhost:6379
# Cloud override: set REDIS_URL to a provider connection string.
# Leave REDIS_URL empty to use the local host/port settings below.
# Render Key Value should use the internal connection string for same-region services.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hypha:
REDIS_TLS=false

# ============ LLM API Keys ============

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek (OpenAI 兼容 API)
#   官方地址: https://platform.deepseek.com
#   base_url 使用 OpenAI 兼容格式: https://api.deepseek.com
#   推荐模型: deepseek-v4-flash (普通/思考一体), deepseek-v4-pro
#   兼容旧名: deepseek-chat / deepseek-reasoner (将于 2026/07/24 弃用)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============ OpenAI 兼容模型 ============
# 这些模型使用 OpenAI 兼容 API

# Kimi (Moonshot) - https://platform.moonshot.cn
KIMI_API_KEY=

# SiliconFlow (硅基流动) - https://www.siliconflow.cn
SILICONFLOW_API_KEY=

# Groq - https://console.groq.com
GROQ_API_KEY=

# Together AI - https://api.together.xyz
TOGETHER_API_KEY=

# Perplexity - https://www.perplexity.ai
PERPLEXITY_API_KEY=

# ============ Auth ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
HYPHA_OWNER_EMAIL=owner@hypha.local
HYPHA_OWNER_USERNAME=owner
HYPHA_OWNER_PASSWORD=hypha_owner_2026
HYPHA_OWNER_DISPLAY_NAME=hypha Owner

# ============ MCP Gateway ============
MCP_GATEWAY_URL=http://localhost:3001
MCP_GATEWAY_TOKEN=
