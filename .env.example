# hypha environment overrides
# config.yaml owns typed defaults and framework structure.
# .env should contain per-deployment overrides, credentials, and local paths.

# Server
HYPHA_APP_NAME=hypha
HYPHA_APP_VERSION=1.0.0
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
HYPHA_API_PREFIX=/api/v1

# Auth and default owner
JWT_SECRET=change-me-local-access-secret
JWT_REFRESH_SECRET=change-me-local-refresh-secret
JWT_EXPIRY_SECONDS=86400
JWT_REFRESH_EXPIRY_SECONDS=604800
HYPHA_OWNER_EMAIL=owner@hypha.local
HYPHA_OWNER_USERNAME=owner
HYPHA_OWNER_PASSWORD=hypha_owner_2026
HYPHA_OWNER_DISPLAY_NAME=hypha Owner

# LLM defaults
HYPHA_LLM_DEFAULT_PROVIDER=openai
HYPHA_LLM_DEFAULT_MODEL=gpt-4o-mini

# LLM provider credentials
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OLLAMA_BASE_URL=http://localhost:11434

# Optional OpenAI-compatible providers
KIMI_API_KEY=
SILICONFLOW_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# MongoDB document store
# Leave MONGODB_URI empty for local host/port. Set it for Atlas or another
# managed/self-hosted MongoDB endpoint.
MONGODB_URI=
MONGODB_DEPLOYMENT=local
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hypha
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_TLS=false
MONGODB_AUTH_SOURCE=
MONGODB_REPLICA_SET=
MONGODB_DIRECT_CONNECTION=

# Redis cache and stream store
# Leave REDIS_URL empty for local host/port. Use rediss:// URLs for managed TLS
# providers. KV_URL and RENDER_REDIS_URL are also recognized as runtime fallbacks.
REDIS_URL=
REDIS_DEPLOYMENT=local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hypha:
REDIS_TLS=false

# Local storage backbone
HYPHA_STORAGE_ROOT=./data/storage
HYPHA_SQLITE_MODE=auto
HYPHA_STORAGE_EVENT_DB=./data/hypha-runtime-events.sqlite
HYPHA_STORAGE_STRUCTURED_DB=./data/hypha-structured.sqlite
HYPHA_STORAGE_VECTOR_INDEX=./data/hypha-vectors.json
HYPHA_STORAGE_ARTIFACT_ROOT=./data/artifacts

# Optional vector database provider endpoints
# These are used by storage.profiles entries when a deployment enables them.
PGVECTOR_URL=
QDRANT_URL=
MILVUS_URL=
CHROMA_URL=
PINECONE_URL=
PINECONE_API_KEY=
PINECONE_REGION=
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Runtime extension paths
HYPHA_SKILLS_DIR=
FILESYSTEM_TOOL_ROOT=

# CLI client overrides
HYPHA_HOME=
HYPHA_BASE_URL=http://127.0.0.1:3000/api/v1
HYPHA_PROVIDER=
HYPHA_MODEL=

# MCP gateway
MCP_GATEWAY_URL=http://localhost:3001
MCP_GATEWAY_TOKEN=

# Development-only helper accounts
DEV_ADMIN_EMAIL=admin@hypha.local
DEV_ADMIN_PASSWORD=hypha_admin_2026
DEV_TEST_EMAIL=dev@test.local
DEV_TEST_PASSWORD=devpassword123
