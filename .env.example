# hypha environment overrides
# config.yaml defines typed structure and safe local defaults.
# .env should contain deployment-specific URLs, credentials, and local paths.

# Server
HYPHA_APP_NAME=hypha
HYPHA_APP_VERSION=1.0.0
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
HYPHA_API_PREFIX=/api/v1

# Auth and default owner
JWT_SECRET=change-me-local-access-secret
HYPHA_OWNER_EMAIL=owner@hypha.local
HYPHA_OWNER_USERNAME=owner
HYPHA_OWNER_PASSWORD=hypha_owner_2026
HYPHA_OWNER_DISPLAY_NAME=hypha Owner

# Storage deployment selector
HYPHA_STORAGE_DEPLOYMENT=local
HYPHA_STORAGE_PROFILE=local

# Document storage: MongoDB
# Leave MONGODB_URI empty for local host/port. Set it for Atlas or another
# managed/self-hosted MongoDB endpoint.
MONGODB_URI=
MONGODB_DEPLOYMENT=local
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=hypha
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_TLS=false
MONGODB_AUTH_SOURCE=
MONGODB_REPLICA_SET=
MONGODB_DIRECT_CONNECTION=

# Messaging/cache/stream storage: Redis
# Leave REDIS_URL empty for local host/port. Use rediss:// URLs for managed TLS
# providers. KV_URL and RENDER_REDIS_URL are also recognized as runtime fallbacks.
REDIS_URL=
REDIS_DEPLOYMENT=local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hypha:
REDIS_TLS=false

# Messaging/queue storage: Kafka
KAFKA_ENABLED=false
KAFKA_DEPLOYMENT=local
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=hypha
KAFKA_SSL=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Relational storage: local SQLite
HYPHA_SQLITE_MODE=auto
HYPHA_STORAGE_EVENT_DB=./data/runtime/events/hypha-runtime-events.sqlite
HYPHA_STORAGE_STRUCTURED_DB=./data/runtime/structured/hypha-structured.sqlite

# Relational storage: Postgres
POSTGRES_ENABLED=false
POSTGRES_DEPLOYMENT=local
POSTGRES_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=hypha
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
POSTGRES_TLS=false

# Vector storage: local JSON index
HYPHA_STORAGE_VECTOR_INDEX=./data/storage/vector/hypha-vectors.json

# Vector storage: external providers
QDRANT_ENABLED=false
QDRANT_DEPLOYMENT=self_hosted
QDRANT_URL=
QDRANT_COLLECTION=hypha_memory
QDRANT_API_KEY=
QDRANT_TLS=false
CHROMA_ENABLED=false
CHROMA_DEPLOYMENT=local
CHROMA_URL=
CHROMA_COLLECTION=hypha_memory
CHROMA_TLS=false
PINECONE_ENABLED=false
PINECONE_DEPLOYMENT=managed
PINECONE_URL=
PINECONE_INDEX=hypha-memory
PINECONE_API_KEY=
PINECONE_REGION=
PINECONE_TLS=true

# Artifact storage
HYPHA_STORAGE_ARTIFACT_ROOT=./data/storage/artifacts
S3_ARTIFACTS_ENABLED=false
S3_ARTIFACTS_DEPLOYMENT=managed
S3_ARTIFACTS_BUCKET=
S3_ARTIFACTS_REGION=
S3_ARTIFACTS_ENDPOINT=

# System logs
HYPHA_SYSTEM_LOG_PATH=./data/logs/system.log

# LLM defaults
HYPHA_LLM_DEFAULT_PROVIDER=openai
HYPHA_LLM_DEFAULT_MODEL=gpt-4o-mini
HYPHA_LLM_DEFAULT_CHAT_TARGET=openai:gpt-4o-mini
HYPHA_LLM_DEFAULT_FAST_TARGET=openai:gpt-4o-mini
HYPHA_LLM_DEFAULT_REASONING_TARGET=openai:gpt-4o-mini

# LLM provider credentials
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OLLAMA_BASE_URL=http://localhost:11434

# Optional OpenAI-compatible providers
KIMI_API_KEY=
SILICONFLOW_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# Runtime extension paths
HYPHA_SKILLS_DIR=
FILESYSTEM_TOOL_ROOT=

# CLI client overrides
HYPHA_HOME=
HYPHA_BASE_URL=http://127.0.0.1:3000/api/v1
HYPHA_PROVIDER=
HYPHA_MODEL=

# MCP gateway
MCP_GATEWAY_URL=http://localhost:3001
MCP_GATEWAY_TOKEN=

# Development-only helper accounts
DEV_ADMIN_EMAIL=admin@hypha.local
DEV_ADMIN_PASSWORD=hypha_admin_2026
DEV_TEST_EMAIL=dev@test.local
DEV_TEST_PASSWORD=devpassword123
